<Window x:Class="FileNest.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="FileNest" Height="720" Width="1180" MinHeight="560" MinWidth="960"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="300" />
        </Grid.ColumnDefinitions>

        <GroupBox Grid.Row="0" Grid.Column="0" Header="정리할 폴더" Margin="0,0,10,0">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top"
                           Margin="8"
                           Text="다운로드, 바탕화면, 문서가 기본으로 들어갑니다. 시스템 폴더는 자동 제외됩니다."
                           TextWrapping="Wrap"
                           Foreground="DimGray" />
                <ListBox Margin="8"
                         ItemsSource="{Binding TargetFolders}"
                         SelectedItem="{Binding SelectedTargetFolder, Mode=TwoWay}" />
            </DockPanel>
        </GroupBox>

        <GroupBox Grid.Row="0" Grid.Column="1" Header="정리 미리보기" Margin="0,0,10,0">
            <DataGrid Margin="8"
                      ItemsSource="{Binding PreviewItems}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      GridLinesVisibility="Horizontal"
                      SelectionMode="Extended">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="원래 파일명" Binding="{Binding FileName}" Width="190" />
                    <DataGridTextColumn Header="현재 위치" Binding="{Binding CurrentLocation}" Width="260" />
                    <DataGridTextColumn Header="이동될 폴더" Binding="{Binding DestinationFolder}" Width="260" />
                    <DataGridTextColumn Header="분류 이유" Binding="{Binding Reason}" Width="*" />
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <GroupBox Grid.Row="0" Grid.Column="2" Header="규칙 목록">
            <DataGrid Margin="8"
                      ItemsSource="{Binding Rules}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      GridLinesVisibility="Horizontal">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="규칙" Binding="{Binding Name}" Width="100" />
                    <DataGridTextColumn Header="조건" Binding="{Binding DisplayCondition}" Width="150" />
                    <DataGridTextColumn Header="이동 폴더" Binding="{Binding DestinationRelativePath}" Width="150" />
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <StackPanel Grid.Row="1" Grid.ColumnSpan="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,8">
            <Button Width="120" Height="34" Margin="4" Content="폴더 추가" Click="AddFolder_Click" />
            <Button Width="140" Height="34" Margin="4" Content="선택 폴더 제거" Click="RemoveFolder_Click" />
            <Button Width="150" Height="34" Margin="4" Content="미리보기 새로고침" Click="RefreshPreview_Click" />
            <Button Width="120" Height="34" Margin="4" Content="정리 실행" Click="Organize_Click" />
            <Button Width="160" Height="34" Margin="4" Content="마지막 정리 되돌리기" Click="Undo_Click" />
            <Button Width="120" Height="34" Margin="4" Content="설정 저장" Click="SaveSettings_Click" />
        </StackPanel>

        <Border Grid.Row="2" Grid.ColumnSpan="3" Padding="10" Background="#FFF4F4F4" CornerRadius="6">
            <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" />
        </Border>
    </Grid>
</Window>
